{
  "$schema": "https://raw.githubusercontent.com/microsoft/AL-Go/646025c59ea7bbf9259bafa0f159900c21b1f285/Actions/.Modules/settings.schema.json",
  "projectName": "Unit Tests",
  "gitHubRunner": "self-hosted, 1ES.Pool=GitHub-BCApps",
  "projectsToTest": [ "build/projects/Apps" ],
  "testFolders": [],
  "runTestsInAllInstalledTestApps": true,
  "installOnlyReferencedApps": false,
  "memoryLimit": "16G",
  "doNotRunTests": false,
  "useCompilerFolder": false,
  "doNotPublishApps": false,
  "testType": "UnitTest",
  "companyName": "Empty Company",
  "buildModes": [
    "IntegrationTests",
    "UncategorizedTests",
    "LegacyTestsBucket1",
    "LegacyTestsBucket2",
    "LegacyTestsBucket3",
    "LegacyTestsBucket4",
    "LegacyTestsBucket5",
    "LegacyTestsBucket6"
  ],
  "ConditionalSettings": [
    {
      "buildModes": [
        "IntegrationTests"
      ],
      "settings": {
        "testType": "IntegrationTest",
        "companyName": "My Company"
      }
    },
    {
      "buildModes": [
        "UncategorizedTests"
      ],
      "settings": {
        "testType": "Uncategorized",
        "companyName": "CRONUS International Ltd."
      }
    },
    {
