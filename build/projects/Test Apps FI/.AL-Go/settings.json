{
  "$schema": "https://raw.githubusercontent.com/microsoft/AL-Go/824449511f8e902e4e529df34bb128349afa307a/Actions/.Modules/settings.schema.json",
  "projectName": "Unit Tests (FI)",
  "gitHubRunner": "GitHub-BCAppsPL",
  "projectsToTest": [
    "build/projects/Apps FI"
  ],
  "testFolders": [],
  "runTestsInAllInstalledTestApps": true,
  "installOnlyReferencedApps": false,
  "memoryLimit": "16G",
  "doNotRunTests": false,
  "useCompilerFolder": false,
  "doNotPublishApps": false,
  "testType": "UnitTest",
  "companyName": "Empty Company",
  "country": "FI",
  "buildModes": [
    "IntegrationTests",
    "UncategorizedTests",
    "LegacyTestsBucket1",
    "LegacyTestsBucket2"
  ],
  "ConditionalSettings": [
    {
      "buildModes": [
        "IntegrationTests"
      ],
      "settings": {
        "testType": "IntegrationTest",
        "companyName": "My Company"
      }
    },
    {
      "buildModes": [
        "UncategorizedTests"
      ],
      "settings": {
        "testType": "Uncategorized",
        "companyName": "CRONUS International Ltd."
      }
    },
    {
      "buildModes": [
        "LegacyTestsBucket1"
      ],
      "settings": {
        "testType": "Legacy",
        "bucketNumber": 1,
        "companyName": "CRONUS International Ltd."
      }
    },
    {
      "buildModes": [
        "LegacyTestsBucket2"
      ],
      "settings": {
        "testType": "Legacy",
        "bucketNumber": 2,
        "companyName": "CRONUS International Ltd."
      }
    }
  ]
}
