{
  "$schema": "https://raw.githubusercontent.com/microsoft/AL-Go-Actions/v9.1/.Modules/settings.schema.json",
  "type": "PTE",
  "templateUrl": "https://github.com/microsoft/AL-Go-PTE@preview",
  "bcContainerHelperVersion": "preview",
  "runs-on": "windows-latest",
  "cacheImageName": "",
  "UsePsSession": false,
  "gitHubRunner": "windows-latest",
  "githubRunnerShell": "pwsh",
  "artifact": "bcinsider/Sandbox/29.0.51936.0//latest",
  "country": "base",
  "useProjectDependencies": true,
  "repoVersion": "29.0",
  "numberOfTenantsForTesting": 3,
  "workspaceCompilation": {
    "enabled": true,
    "parallelism": -1
  },
  "conditionalSettings": [
    {
      "buildModes": [
        "Clean"
      ],
      "settings": {
        "preprocessorSymbols": [
          "CLEAN25",
          "CLEAN26",
          "CLEAN27",
          "CLEAN28",
          "CLEAN29"
        ]
      }
    },
    {
      "projects": [
        "."
      ],
      "settings": {
        "appFolders": [
          "src/Layers/W1/DemoTool"
        ]
      }
    }
  ],
  "customALGoFiles": {
    "filesToExclude": [
      {
        "sourceFolder": ".github/workflows",
        "filter": "AddExistingAppOrTestApp.yaml"
      },
      {
        "sourceFolder": ".github/workflows",
        "filter": "CreateApp.yaml"
      },
      {
        "sourceFolder": ".github/workflows",
        "filter": "CreateOnlineDevelopmentEnvironment.yaml"
      },
      {
        "sourceFolder": ".github/workflows",
        "filter": "CreatePerformanceTestApp.yaml"
      },
      {
        "sourceFolder": ".github/workflows",
        "filter": "CreateRelease.yaml"
      },
      {
        "sourceFolder": ".github/workflows",
        "filter": "CreateTestApp.yaml"
      },
      {
        "sourceFolder": ".github/workflows",
        "filter": "Current.yaml"
      },
      {
        "sourceFolder": ".github/workflows",
        "filter": "NextMajor.yaml"
      },
      {
        "sourceFolder": ".github/workflows",
        "filter": "NextMinor.yaml"
      },
      {
        "sourceFolder": ".github/workflows",
        "filter": "PublishToEnvironment.yaml"
      },
      {
        "sourceFolder": ".github",
        "filter": "Test Current.settings.json"
      },
      {
        "sourceFolder": ".github",
        "filter": "Test Next Minor.settings.json"
      },
      {
        "sourceFolder": ".github",
        "filter": "Test Next Major.settings.json"
      }
    ]
  },
  "excludeEnvironments": [
    "Official-Build"
  ],
  "buildModes": [
    "Default"
  ],
  "CICDPushBranches": [
    "main",
    "releases/*"
  ],
  "CICDPullRequestBranches": [
    "main",
    "releases/*",
    "features/*"
  ],
  "enableCodeCop": true,
  "enableAppSourceCop": true,
  "enablePerTenantExtensionCop": true,
  "enableUICop": true,
  "enableCodeAnalyzersOnTestApps": true,
  "rulesetFile": "../../../src/rulesets/base.ruleset.json",
  "skipUpgrade": true,
  "fullBuildPatterns": [
    "eng/*",
    "src/rulesets/*",
    "src/Layers/*",
    ".github/workflows/PullRequestHandler.yaml",
    ".github/workflows/_BuildALGoProject.yaml"
  ],
  "PullRequestTrigger": "pull_request",
  "ALDoc": {
    "maxReleases": 0,
    "continuousDeployment": false,
    "groupByProject": false,
    "includeProjects": [
      "build_projects_Apps W1"
    ],
    "excludeProjects": [
      "eng_AL-Go_System Application Modules"
    ]
  },
  "UpdateALGoSystemFilesEnvironment": "Official-Build",
  "templateSha": "ed18f419100ead6deece0a6738111ac2d190c57c",
  "commitOptions": {
    "messageSuffix": "Related to AB#539394",
    "pullRequestAutoMerge": true,
    "pullRequestLabels": [
      "Automation"
    ]
  },
  "runNumberOffset": 60000,
  "incrementalBuilds": {
    "onPush": false,
    "onPull_Request": true,
    "onSchedule": false,
    "mode": "modifiedApps"
  }
}
