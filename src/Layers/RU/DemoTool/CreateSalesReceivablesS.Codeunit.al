codeunit 101311 "Create Sales & Receivables S."
{

    trigger OnRun()
    var
        ExcelTemplate: Record "Excel Template";
    begin
        DemoDataSetup.Get();
        "Sales & Receivables Setup".Get();
        "Sales & Receivables Setup".Validate("Shipment on Invoice", true);
        "Sales & Receivables Setup".Validate("Return Receipt on Credit Memo", true);
        "Sales & Receivables Setup".Validate("Discount Posting", "Sales & Receivables Setup"."Discount Posting"::"No Discounts");
        "Sales & Receivables Setup".Validate("Invoice Rounding", true);
        "Sales & Receivables Setup".Validate("Customer Group Dimension Code", XCUSTOMERGROUP);
        "Sales & Receivables Setup".Validate("Salesperson Dimension Code", XSALESPERSON);
        "Sales & Receivables Setup"."Copy Customer Name to Entries" := true;
        "Create No. Series".InitBaseSeries("Sales & Receivables Setup"."Customer Nos.", XSAL + '-01-01', XCustomersLegalEntities, XCLE + '-001', '', '', '', 1);
        "Create No. Series".InitBaseSeries("Sales & Receivables Setup"."Customer Nos.", XSAL + '-01-02', XCustomersPhysicalPersons, XCPP + '-001', '', '', '', 1);
        "Create No. Series".InitBaseSeries("Sales & Receivables Setup"."Customer Nos.", XSAL + '-01-03', XCustomersCommissioners, XCCM + '-001', '', '', '', 1);
        "Create No. Series".InitBaseSeries("Sales & Receivables Setup"."Customer Nos.", XSAL + '-01-04', XCustomersSubCommissioners, XCSC + '-001', '', '', '', 1);
        "Create No. Series".InitBaseSeries("Sales & Receivables Setup"."Customer Nos.", XSAL + '-01-05', XCustomersEntrepreneurs, XCEN + '-001', '', '', '', 1);
        "Create No. Series".InitBaseSeries("Sales & Receivables Setup"."Customer Nos.", XSAL + '-01-06', XCustomersEmployees, XCEM + '-001', '', '', '', 1);
        "Create No. Series".InitBaseSeries("Sales & Receivables Setup"."Customer Nos.", XSAL + '-01-07', XCustomersShareholders, XCSH + '-001', '', '', '', 1);
        "Create No. Series".InitBaseSeries("Sales & Receivables Setup"."Customer Nos.", XSAL + '-01-08', XCustomersBanksandLoaners, XCBL + '-001', '', '', '', 1);
