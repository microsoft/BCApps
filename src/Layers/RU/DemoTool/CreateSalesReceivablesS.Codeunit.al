        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Prepayment Nos.", XSPREP, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Prepayment Nos.", XSPREP, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Posted Prepmt. Inv. Nos.", XSAL + '-31', XPrepaymentSalesInvoice, true, false, false);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Prepmt. Inv. Nos.", XSPRINV, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Prepmt. Inv. Nos.", XSPRINV, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Posted Prepmt. Cr. Memo Nos.", XSAL + '-32', XPrepaymentSalesCreditMemo, true, false, false);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Prepmt. Cr. Memo Nos.", XSPRCRM, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Prepmt. Cr. Memo Nos.", XSPRCRM, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Posted PD Doc. Nos.", XSAL + '-33', XPrepaymentDifferences, true, false, false);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted PD Doc. Nos.", XSPD, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted PD Doc. Nos.", XSPD, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Canc. Iss. Fin. Ch. Mem. Nos.", XSFINCPLUS + '-12', XCanceledIssuedFinanceChargeMemo, false, true, true);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Canceled Issued Reminder Nos.", XSREMCPLUS + '-12', XCanceledIssuedReminder, false, true, true);
        "Sales & Receivables Setup"."Appln. between Currencies" := "Sales & Receivables Setup"."Appln. between Currencies"::All;
        "Sales & Receivables Setup"."Document Default Line Type" := "Sales & Receivables Setup"."Document Default Line Type"::Item;

        "Sales & Receivables Setup".Validate("Use Prepayment Account", true);
        "Sales & Receivables Setup".Validate("Create Prepayment Invoice", true);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Customer Agreement Nos.", XSAL + '-02', XCustomerAgreements, true, false, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Customer Agreement Nos.", XSAGR, 10000, 0D, 1);
        "Sales & Receivables Setup".Validate("Customer Agreement Dim. Code", XAGREEMENT);
        "Sales & Receivables Setup".Validate("Synch. Agreement Dimension", false);
        "Sales & Receivables Setup".Validate("Credit Warnings", "Sales & Receivables Setup"."Credit Warnings"::"Both Warnings");
        "Sales & Receivables Setup".Validate("Stockout Warning", true);
        "Sales & Receivables Setup".Validate("Calc. Inv. Discount", false);
        "Sales & Receivables Setup"."Copy Comments Blanket to Order" := true;
        "Sales & Receivables Setup"."Copy Comments Order to Invoice" := true;
        "Sales & Receivables Setup"."Copy Comments Order to Shpt." := true;
        "Sales & Receivables Setup"."Copy Cmts Ret.Ord. to Ret.Rcpt" := true;
        "Sales & Receivables Setup"."Copy Cmts Ret.Ord. to Cr. Memo" := true;
        "Sales & Receivables Setup"."Return Receipt on Credit Memo" := true;
        "Sales & Receivables Setup".Validate("Allow VAT Difference", true);
        "Sales & Receivables Setup".Validate("Default Posting Date", "Sales & Receivables Setup"."Default Posting Date"::"Work Date");
        "Sales & Receivables Setup".Validate("Default Quantity to Ship", "Sales & Receivables Setup"."Default Quantity to Ship"::Remainder);
        "Sales & Receivables Setup".Validate("Transfer Posting Description", true);
        "Sales & Receivables Setup".Validate("Calc. VAT per Line", true);
        "Sales & Receivables Setup".Validate("PD Doc. Nos. Type", "Sales & Receivables Setup"."PD Doc. Nos. Type"::"Add Symbol");
        "Sales & Receivables Setup".Validate("Symbol for PD Doc.", XPD);
        "Sales & Receivables Setup".Validate("Allow Alter Posting Groups", true);

        "Sales & Receivables Setup"."Factura Template Code" := XFACTURA;
        ExcelTemplate.InsertTemplate(XFACTURA, XFacturaInvoice, 'LocalFiles\Facture.xlsx');
        "Sales & Receivables Setup"."Corr. Factura Template Code" := XCORRFACTURA;
        ExcelTemplate.InsertTemplate(
          XCORRFACTURA, XCorrFacturaInvoice, 'LocalFiles\CorrectingFacture.xlsx');
        "Sales & Receivables Setup"."Proforma Template Code" := XPROFORMA;
        ExcelTemplate.InsertTemplate(XPROFORMA, XProformaInvoice, 'LocalFiles\Proforma.xlsx');
        "Sales & Receivables Setup"."TORG-12 Template Code" := XTORG12;
        ExcelTemplate.InsertTemplate(XTORG12, XShipmentTORG12, 'LocalFiles\TORG-12.xlsx');
        "Sales & Receivables Setup"."Sales Shipment M-15 Templ.Code" := XM15;
        ExcelTemplate.InsertTemplate(XM15, XM15, 'LocalFiles\M-15.xlsx');
        "Sales & Receivables Setup"."Bill of Lading Template Code" := XBOL;
        ExcelTemplate.InsertTemplate(XBOL, XBillOfLading, 'LocalFiles\BillOfLading.xlsx');

        "Sales & Receivables Setup".Modify();
    end;

    var
        DemoDataSetup: Record "Demo Data Setup";
        "Sales & Receivables Setup": Record "Sales & Receivables Setup";
        "Create No. Series": Codeunit "Create No. Series";
        XCUST: Label 'CUST';
        XCustomer: Label 'Customer';
        XC10: Label 'C10';
        XC99990: Label 'C99990';
        XSQUO: Label 'SQ';
        XSalesQuote: Label 'Sales Quote';
        XSBLK: Label 'SB';
        XBlanketSalesOrder: Label 'Blanket Sales Order';
        XSORD: Label 'SO';
        XSalesOrder: Label 'Sales Order';
        XSRETORD: Label 'SRO';
        XSalesReturnOrder: Label 'Sales Return Order';
        XSSHPT: Label 'SS';
        XSalesShipment: Label 'Sales Shipment';
        XSINV: Label 'USI';
        XSalesInvoice: Label 'Sales Invoice';
        XSINVplus: Label 'SI';
        XPostedSalesInvoice: Label 'Posted Sales Invoice';
        XSCR: Label 'USC';
        XSalesCreditMemo: Label 'Sales Credit Memo';
        XSRCPT: Label 'SR';
        XPostedSalesReceipt: Label 'Posted Sales Receipt';
        XSCRPLUS: Label 'SC';
        XPostedSalesCreditMemo: Label 'Posted Sales Credit Memo';
        XSREM: Label 'USRM';
        XSPL: Label 'S-PL';
