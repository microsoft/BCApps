        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Quote Nos.", XSQUO, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Blanket Order Nos.", XSAL + '-11', XBlanketSalesOrder, true, false, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Blanket Order Nos.", XSBLK, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Blanket Order Nos.", XSBLK, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Order Nos.", XSAL + '-12', XSalesOrder, false, true, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Order Nos.", XSORD, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Order Nos.", XSORD, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Invoice Nos.", XSAL + '-13', XSalesInvoice, false, true, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Invoice Nos.", XSINV, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Invoice Nos.", XSINV, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Posted Invoice Nos.", XSAL + '-14', XPostedSalesInvoice, true, false, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Invoice Nos.", XSINVplus, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Invoice Nos.", XSINVplus, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Posted Shipment Nos.", XSAL + '-15', XSalesShipment, true, false, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Shipment Nos.", XSSHPT, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Shipment Nos.", XSSHPT, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Credit Memo Nos.", XSAL + '-16', XSalesCreditMemo, true, false, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Credit Memo Nos.", XSCR, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Credit Memo Nos.", XSCR, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Posted Credit Memo Nos.", XSAL + '-17', XPostedSalesCreditMemo, true, false, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Credit Memo Nos.", XSCRPLUS, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Credit Memo Nos.", XSCRPLUS, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Return Order Nos.", XSAL + '-18', XSalesReturnOrder, true, false, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Return Order Nos.", XSRETORD, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Return Order Nos.", XSRETORD, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Posted Return Receipt Nos.", XSAL + '-19', XPostedSalesReceipt, true, false, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Return Receipt Nos.", XSRCPT, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Posted Return Receipt Nos.", XSRCPT, 20000, 19030101D, 1);
        "Create No. Series".InitBaseSeries("Sales & Receivables Setup"."Price List Nos.", XSPL, XSalesPriceList, XS00001, XS99999, '', '', 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Reminder Nos.", XSAL + '-41', XReminder, true, false, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Reminder Nos.", XSREM, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Reminder Nos.", XSREM, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Issued Reminder Nos.", XSAL + '-42', XIssuedReminder, true, false, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Issued Reminder Nos.", XSREMPLUS, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Issued Reminder Nos.", XSREMPLUS, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Fin. Chrg. Memo Nos.", XSAL + '-43', XFinanceChargeMemo, true, false, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Fin. Chrg. Memo Nos.", XSFIN, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Fin. Chrg. Memo Nos.", XSFIN, 20000, 19030101D, 1);
        "Create No. Series".InsertSeriesOnly("Sales & Receivables Setup"."Issued Fin. Chrg. M. Nos.", XSAL + '-44', XIssuedFinanceChargeMemo, true, false, true);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Issued Fin. Chrg. M. Nos.", XSFINPLUS, 10000, 19020101D, 1);
        "Create No. Series".InsertSeriesLine("Sales & Receivables Setup"."Issued Fin. Chrg. M. Nos.", XSFINPLUS, 20000, 19030101D, 1);
