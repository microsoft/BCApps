        "Create No. Series".InsertRelation(XSAL + '-01-01', XSAL + '-01-03');
        "Create No. Series".InsertRelation(XSAL + '-01-01', XSAL + '-01-04');
        "Create No. Series".InsertRelation(XSAL + '-01-01', XSAL + '-01-05');
        "Create No. Series".InsertRelation(XSAL + '-01-01', XSAL + '-01-06');
        "Create No. Series".InsertRelation(XSAL + '-01-01', XSAL + '-01-07');
