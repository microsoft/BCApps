        XSREMPLUS: Label 'SRM';
        XIssuedReminder: Label 'Issued Reminder';
        XSFIN: Label 'USF';
        XSREMCPLUS: Label 'S-REM-C+';
        XFinanceChargeMemo: Label 'Finance Charge Memo';
        XSFINPLUS: Label 'SF';
        XIssuedFinanceChargeMemo: Label 'Issued Finance Charge Memo';
        XSFINCPLUS: Label 'S-FIN-C+';
        XCanceledIssuedFinanceChargeMemo: Label 'Canceled Issued Finance Charge Memo';
        XCUSTOMERGROUP: Label 'CUSTOMERGROUP';
        XSALESPERSON: Label 'SALESPERSON';
        XCustomerAgreements: Label 'Customer Agreements';
        XAGREEMENT: Label 'AGREEMENT';
        XSAL: Label 'SAL';
        XCustomersLegalEntities: Label 'Customers, Legal Entities';
        XCLE: Label 'CLE';
        XCustomersPhysicalPersons: Label 'Customers, Physical Persons';
        XCPP: Label 'CPP';
        XCustomersCommissioners: Label 'Customers, Commissioners';
        XCCM: Label 'CCM';
        XCustomersSubCommissioners: Label 'Customers, Sub-Commissioners';
        XCSC: Label 'CSC';
        XCustomersEntrepreneurs: Label 'Customers, Entrepreneurs';
        XCEN: Label 'CEN';
        XCustomersEmployees: Label 'Customers, Employees';
        XCEM: Label 'CEM';
        XCustomersShareholders: Label 'Customers, Shareholders';
        XCSH: Label 'CSH';
        XCustomersBanksandLoaners: Label 'Customers, Banks and Loaners';
        XCBL: Label 'CBL';
