<?xml version="1.0" encoding="windows-1251"?>
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <xsd:annotation>
    <xsd:documentation xml:lang="ru">XML-схема для проверки входящих документов - Структура пачки </xsd:documentation>
  </xsd:annotation>
  <xsd:element name="ФайлПФР">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="ИмяФайла" type="ТипИмяФайла" />
        <xsd:element name="ЗаголовокФайла">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="ВерсияФормата">
                <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                    <xsd:enumeration value="07.00" />
                  </xsd:restriction>
                </xsd:simpleType>
              </xsd:element>
              <xsd:element name="ТипФайла">
                <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                    <xsd:enumeration value="ВНЕШНИЙ" />
                  </xsd:restriction>
                </xsd:simpleType>
              </xsd:element>
              <xsd:element name="ПрограммаПодготовкиДанных">
                <xsd:complexType>
                  <xsd:sequence>
                    <xsd:element name="НазваниеПрограммы" type="Тип40" />
                    <xsd:element name="Версия">
                      <xsd:simpleType>
                        <xsd:restriction base="xsd:string">
                          <xsd:minLength value="1" />
                          <xsd:maxLength value="10" />
                        </xsd:restriction>
                      </xsd:simpleType>
                    </xsd:element>
                  </xsd:sequence>
                </xsd:complexType>
              </xsd:element>
              <xsd:element name="ИсточникДанных">
                <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                    <xsd:enumeration value="СТРАХОВАТЕЛЬ" />
                    <xsd:enumeration value="ТРАНСФЕР-АГЕНТ" />
                    <xsd:enumeration value="ОПФР-ЛИЧНО" />
                    <xsd:enumeration value="ОПФР-ПРОЧЕЕ" />
                    <xsd:enumeration value="НПФ" />
                    <xsd:enumeration value="ПФР" />
                    <xsd:enumeration value="ОРГАН_ЗАГС" />
                  </xsd:restriction>
                </xsd:simpleType>
              </xsd:element>
            </xsd:sequence>
          </xsd:complexType>
        </xsd:element>
        <xsd:element name="ПачкаВходящихДокументов">
          <xsd:complexType>
            <xsd:choice>
              <xsd:element name="РАСЧЕТ_ПО_СТРАХОВЫМ_ВЗНОСАМ_НА_ОПС_И_ОМС_ПЛАТЕЛЬЩИКАМИ_СВ_ПРОИЗВОДЯЩИМИ_ВЫПЛАТЫ_ФЛ_НАЧИНАЯ_С_2012_ГОДА" type="ТипВхДокПФР" />
            </xsd:choice>
            <xsd:attribute name="Окружение" use="required">
              <xsd:simpleType>
                <xsd:restriction base="xsd:string">
                  <xsd:enumeration value="Единичный запрос" />
                  <xsd:enumeration value="В составе файла" />
                </xsd:restriction>
              </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="Стадия" use="optional">
              <xsd:simpleType>
                <xsd:restriction base="xsd:string">
                  <xsd:enumeration value="До обработки" />
                  <xsd:enumeration value="После обработки" />
                </xsd:restriction>
              </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="ДобровольныеПравоотношения" use="optional">
              <xsd:simpleType>
                <xsd:restriction base="xsd:string">
                  <xsd:enumeration value="ДСВ" />
                </xsd:restriction>
              </xsd:simpleType>
            </xsd:attribute>
          </xsd:complexType>
        </xsd:element>
      </xsd:sequence>
    </xsd:complexType>
  </xsd:element>
  <xsd:simpleType name="ТипДата">
    <xsd:restriction base="xsd:string">
      <xsd:pattern value="\d{2}\.\d{2}\.\d{4}" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипДатаН">
    <xsd:restriction base="xsd:string">
      <xsd:pattern value="\d{2}\.\d{2}\.\d{4}|" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--Тип Дата Особая-->
  <xsd:complexType name="ТипДатаОсобая">
    <xsd:sequence>
      <xsd:element name="День" minOccurs="0">
        <xsd:simpleType>
          <xsd:restriction base="xsd:integer">
            <xsd:minInclusive value="0" />
            <xsd:maxInclusive value="31" />
            <xsd:totalDigits value="2" />
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
      <xsd:element name="Месяц" minOccurs="0">
        <xsd:simpleType>
          <xsd:restriction base="xsd:integer">
            <xsd:minInclusive value="0" />
            <xsd:maxInclusive value="12" />
            <xsd:totalDigits value="2" />
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
      <xsd:element name="Год" type="xsd:gYear" />
    </xsd:sequence>
  </xsd:complexType>
  <!--Тип ФИО -->
  <xsd:complexType name="ТипФИО">
    <xsd:sequence>
      <xsd:element name="Фамилия" type="Тип40" />
      <xsd:element name="Имя" type="Тип40" />
      <xsd:element name="Отчество" type="Тип40Н" minOccurs="0" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипФИОН">
    <xsd:sequence>
      <xsd:element name="Фамилия" type="Тип40Н" minOccurs="0" />
      <xsd:element name="Имя" type="Тип40Н" minOccurs="0" />
      <xsd:element name="Отчество" type="Тип40Н" minOccurs="0" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:simpleType name="ТипПол">
    <xsd:restriction base="ТипПолН">
      <xsd:minLength value="1" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипПолН">
    <xsd:restriction base="xsd:string">
      <xsd:enumeration value="МУЖСКОЙ" />
      <xsd:enumeration value="ЖЕНСКИЙ" />
      <xsd:enumeration value="М" />
      <xsd:enumeration value="Ж" />
      <xsd:enumeration value="" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--Тип СтраховойНомер -->
  <xsd:simpleType name="ТипСтраховойНомер">
    <xsd:restriction base="ТипСтраховойНомерН">
      <xsd:minLength value="14" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипСтраховойНомерН">
    <xsd:restriction base="xsd:string">
      <xsd:pattern value="\d{3}-\d{3}-\d{3} \d{2}" />
      <xsd:pattern value="\d{3}-\d{3}-\d{3}-\d{2}|" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--Тип Регистрационный Номер -->
  <xsd:simpleType name="ТипРегНомер">
    <xsd:restriction base="xsd:string">
      <xsd:pattern value="\d{3}-\d{3}-\d{6}" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--Тип КПП -->
  <xsd:simpleType name="ТипКПП">
    <xsd:restriction base="xsd:string">
      <xsd:pattern value="\d{9}|\d{12}|" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--Тип НН налоговый номер -->
  <xsd:complexType name="ТипНН">
    <xsd:sequence>
      <xsd:element name="ИНН" type="ТипИНН" />
      <xsd:element name="КПП" type="ТипКПП" minOccurs="0" />
    </xsd:sequence>
  </xsd:complexType>
  <!--Тип Номер документа в пачке 1..999 -->
  <xsd:simpleType name="ТипНомерВПачке">
    <xsd:restriction base="xsd:integer">
      <xsd:minInclusive value="1" />
      <xsd:maxInclusive value="999" />
      <xsd:totalDigits value="3" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--Тип имя файла -->
  <xsd:simpleType name="ТипИмяФайла">
    <xsd:restriction base="xsd:string">
      <xsd:pattern value="PFR-700-Y-\d{4}-ORG-\d{3}-\d{3}-\d{6}-DCK-\d{5}-DPT-\d{6}-DCK-\d{5}.XML" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--Тип дата для печати -->
  <xsd:simpleType name="Тип21">
    <xsd:restriction base="xsd:string">
      <xsd:minLength value="8" />
      <xsd:maxLength value="21" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--Тип Наименование портфеля -->
  <xsd:simpleType name="Тип100Н">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="100" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипНомер">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="20" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="Тип200Н">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="200" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--Тип Номер пачки -->
  <xsd:simpleType name="ТипНомерПачки">
    <xsd:restriction base="xsd:positiveInteger">
      <xsd:maxInclusive value="99999" />
      <xsd:totalDigits value="5" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="Тип40">
    <xsd:restriction base="xsd:string">
      <xsd:minLength value="1" />
      <xsd:maxLength value="40" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="Тип30">
    <xsd:restriction base="xsd:string">
      <xsd:minLength value="1" />
      <xsd:maxLength value="30" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="Тип200">
    <xsd:restriction base="xsd:string">
      <xsd:minLength value="1" />
      <xsd:maxLength value="200" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="Тип40Н">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="40" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="Тип30Н">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="30" />
    </xsd:restriction>
  </xsd:simpleType>
  <!-- Тип Подразделение -->
  <xsd:complexType name="ТипПодразделение">
    <xsd:sequence>
      <xsd:element name="НаименованиеПодразделения" type="Тип100Н" />
      <xsd:element name="НомерПодразделения">
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
            <xsd:minLength value="1" />
            <xsd:maxLength value="6" />
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
    </xsd:sequence>
  </xsd:complexType>
  <!--Тип Наименование организации -->
  <xsd:simpleType name="ТипИмяОрг">
    <xsd:restriction base="xsd:string">
      <xsd:minLength value="1" />
      <xsd:maxLength value="100" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--Тип ИНН -->
  <xsd:simpleType name="ТипИНН">
    <xsd:restriction base="xsd:string">
      <xsd:pattern value="\d{10}|\d{12}" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипКодЕГРИП">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="15" />
      <xsd:pattern value="\d{15}|0|" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипКодЕГРЮЛ">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="13" />
      <xsd:pattern value="\d{13}|0|" />
    </xsd:restriction>
  </xsd:simpleType>
  <!-- Тип Организация -->
  <xsd:complexType name="ТипОрганизация">
    <xsd:sequence>
      <xsd:element name="НалоговыйНомер" type="ТипНН" minOccurs="0" />
      <xsd:element name="КодЕГРИП" type="ТипКодЕГРИП" minOccurs="0" />
      <xsd:element name="КодЕГРЮЛ" type="ТипКодЕГРЮЛ" minOccurs="0" />
      <xsd:element name="Форма" type="Тип40Н" minOccurs="0" />
      <xsd:element name="НаименованиеОрганизации" type="Тип100Н" minOccurs="0" />
      <xsd:element name="НаименованиеКраткое" type="Тип100Н" minOccurs="0" />
      <xsd:element name="РегистрационныйНомер" type="ТипРегНомер" minOccurs="0" />
      <xsd:element name="Подразделение" type="ТипПодразделение" minOccurs="0" />
      <xsd:element name="НомерЛицензии" type="xsd:string" minOccurs="0" />
      <xsd:element name="ДатаВыдачиЛицензии" type="ТипДата" minOccurs="0" />
    </xsd:sequence>
  </xsd:complexType>
  <!--Тип Текст -->
  <xsd:simpleType name="Тип100">
    <xsd:restriction base="xsd:string">
      <xsd:minLength value="1" />
      <xsd:maxLength value="100" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--Тип НомерПоЖурналу -->
  <xsd:simpleType name="ТипНомерПоЖурналу">
    <xsd:restriction base="xsd:string">
      <xsd:minLength value="0" />
      <xsd:maxLength value="20" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--Тип НомерУведомления -->
  <xsd:simpleType name="ТипНомерУведомления">
    <xsd:restriction base="xsd:string">
      <xsd:minLength value="1" />
      <xsd:maxLength value="20" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипАнкетные">
    <xsd:restriction base="Тип40Н">
      <xsd:maxLength value="40" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:complexType name="ТипАдресОбщий">
    <xsd:sequence>
      <xsd:element name="ТипАдреса" type="ТипТипАдреса" />
      <xsd:element name="Индекс" type="ТипИндекс" minOccurs="0" />
      <xsd:choice>
        <xsd:element name="РоссийскийАдрес">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="СостояниеАдреса" minOccurs="0">
                <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                    <xsd:maxLength value="20" />
                    <xsd:enumeration value="ПРАВИЛЬНЫЙ" />
                    <xsd:enumeration value="ОШИБОЧНЫЙ" />
                  </xsd:restriction>
                </xsd:simpleType>
              </xsd:element>
              <xsd:element name="Регион" type="ТипГеография" minOccurs="0" />
              <xsd:element name="Район" type="ТипГеография" minOccurs="0" />
              <xsd:element name="Город" type="ТипГеография" minOccurs="0" />
              <xsd:element name="НаселенныйПункт" type="ТипГеография" minOccurs="0" />
              <xsd:element name="Улица" type="ТипГеография" minOccurs="0" />
              <xsd:element name="Дом" type="ТипНумерация" minOccurs="0" />
              <xsd:element name="Корпус" type="ТипНумерация" minOccurs="0" />
              <xsd:element name="Квартира" type="ТипНумерация" minOccurs="0" />
            </xsd:sequence>
          </xsd:complexType>
        </xsd:element>
        <xsd:element name="ИностранныйАдрес">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="КодСтраны">
                <xsd:simpleType>
                  <xsd:restriction base="xsd:positiveInteger">
                    <xsd:minInclusive value="1" />
                    <xsd:maxInclusive value="999" />
                  </xsd:restriction>
                </xsd:simpleType>
              </xsd:element>
              <xsd:element name="НазваниеСтраны" type="Тип100" />
              <xsd:element name="Адрес" type="Тип200Н" />
            </xsd:sequence>
          </xsd:complexType>
        </xsd:element>
        <xsd:element name="НеструктурированныйАдрес">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="Адрес" type="Тип200Н" />
            </xsd:sequence>
          </xsd:complexType>
        </xsd:element>
      </xsd:choice>
    </xsd:sequence>
  </xsd:complexType>
  <xsd:simpleType name="ТипТипАдреса">
    <xsd:restriction base="Тип40">
      <xsd:enumeration value="РОССИЙСКИЙ" />
      <xsd:enumeration value="НЕСТРУКТУРИРОВАННЫЙ" />
      <xsd:enumeration value="ИНОСТРАННЫЙ" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипИндекс">
    <xsd:restriction base="xsd:string">
      <xsd:pattern value="\d{6}|" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:complexType name="ТипГеография">
    <xsd:sequence>
      <xsd:element name="ГеографическоеНазвание" type="Тип200Н" minOccurs="0" />
      <xsd:element name="Сокращение" type="Тип30Н" minOccurs="0" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипНумерация">
    <xsd:sequence>
      <xsd:element name="Сокращение" type="Тип30Н" minOccurs="0" />
      <xsd:element name="Номер" type="ТипНомер" minOccurs="0" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипМестоРождения">
    <xsd:sequence>
      <xsd:element name="ТипМестаРождения">
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
            <xsd:minLength value="1" />
            <xsd:maxLength value="15" />
            <xsd:enumeration value="ОСОБОЕ" />
            <xsd:enumeration value="СТАНДАРТНОЕ" />
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
      <xsd:element name="ГородРождения" type="Тип200Н" minOccurs="0" />
      <xsd:element name="РайонРождения" type="Тип200Н" minOccurs="0" />
      <xsd:element name="РегионРождения" type="Тип200Н" minOccurs="0" />
      <xsd:element name="СтранаРождения" type="Тип200Н" minOccurs="0" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипДокумент">
    <xsd:sequence>
      <xsd:element name="НаименованиеУдостоверяющего">
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
            <xsd:maxLength value="80" />
            <xsd:minLength value="1" />
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
      <xsd:element name="СерияРимскиеЦифры" minOccurs="0">
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
            <xsd:maxLength value="8" />
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
      <xsd:element name="СерияРусскиеБуквы" minOccurs="0">
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
            <xsd:maxLength value="8" />
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
      <xsd:element name="НомерУдостоверяющего" minOccurs="0">
        <xsd:simpleType>
          <xsd:restriction base="xsd:unsignedLong">
            <xsd:minInclusive value="0" />
            <xsd:maxInclusive value="99999999" />
            <xsd:totalDigits value="8" />
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
      <xsd:element name="ДатаВыдачи" type="ТипДата" />
      <xsd:element name="КемВыдан" minOccurs="0">
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
            <xsd:maxLength value="80" />
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипУдостоверяющийДокумент">
    <xsd:sequence>
      <xsd:element name="ТипУдостоверяющего">
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
            <xsd:maxLength value="14" />
            <xsd:enumeration value="ПАСПОРТ" />
            <xsd:enumeration value="ЗГПАСПОРТ" />
            <xsd:enumeration value="СВИД О РОЖД" />
            <xsd:enumeration value="УДОСТ ОФИЦЕРА" />
            <xsd:enumeration value="СПРАВКА ОБ ОСВ" />
            <xsd:enumeration value="ПАСПОРТ МОРФЛТ" />
            <xsd:enumeration value="ВОЕННЫЙ БИЛЕТ" />
            <xsd:enumeration value="ДИППАСПОРТ РФ" />
            <xsd:enumeration value="ИНПАСПОРТ" />
            <xsd:enumeration value="СВИД БЕЖЕНЦА" />
            <xsd:enumeration value="ВИД НА ЖИТЕЛЬ" />
            <xsd:enumeration value="УДОСТ БЕЖЕНЦА" />
            <xsd:enumeration value="ВРЕМ УДОСТ" />
            <xsd:enumeration value="ПАСПОРТ РОССИИ" />
            <xsd:enumeration value="ЗГПАСПОРТ РФ" />
            <xsd:enumeration value="ПАСПОРТ МОРЯКА" />
            <xsd:enumeration value="ВОЕН БИЛЕТ ОЗ" />
            <xsd:enumeration value="ПРОЧЕЕ" />
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
      <xsd:element name="Документ" type="ТипДокумент" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипАнкета">
    <xsd:sequence>
      <xsd:element name="ФИО" type="ТипФИО" />
      <xsd:element name="Пол" type="ТипПол" />
      <xsd:choice>
        <xsd:element name="ДатаРождения" type="ТипДата" />
        <xsd:element name="ДатаРожденияОсобая" type="ТипДатаОсобая" />
      </xsd:choice>
      <xsd:element name="МестоРождения" type="ТипМестоРождения" />
      <xsd:element name="Гражданство" type="Тип40Н" minOccurs="0" />
      <xsd:element name="АдресРегистрации" type="ТипАдресОбщий" minOccurs="0" />
      <xsd:element name="АдресФактический" type="ТипАдресОбщий" minOccurs="0" />
      <xsd:element name="Телефон" type="Тип40Н" minOccurs="0" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипАнкетаН">
    <xsd:sequence>
      <xsd:element name="ФИО" type="ТипФИОН" minOccurs="0" />
