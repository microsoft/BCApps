      <xsd:element name="УдельныйВесЧисленности" type="ТипПоказательУдельныйВес" />
      <xsd:element name="ФондОплатыТруда" type="ТипПоказательРасчетСумм" />
      <xsd:element name="ЗарплатаИнвалидов" type="ТипПоказательРасчетСумм" />
      <xsd:element name="УдельныйВесЗарплатыИнвалидов" type="ТипПоказательУдельныйВес" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипРасчетСоответствияУсловийНаПравоПримененияПониженногоТарифа">
    <xsd:sequence>
      <xsd:element name="ДляОбщественныхОрганизацийИнвалидов" type="ТипДляОбщественныхОрганизацийИнвалидов" minOccurs="0" />
      <xsd:element name="ДляОрганизацийУставныйКапиталСостоитИзВкладовОбщОргИнвалидов" type="ТипДляОрганизацийУставныйКапиталСостоитИзВкладовОбщОргИнвалидов" minOccurs="0" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипПериодИндивидуальнойТрудовойДеятельности">
    <xsd:sequence>
      <xsd:element name="НомерПП" type="ТипНомерПоПорядку" />
      <xsd:element name="ДатаНачалаПериода" type="ТипДата" />
      <xsd:element name="ДатаКонцаПериода" type="ТипДата" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипРасчетНачисленийСтраховыхВзносовЗаЧленаФХ">
    <xsd:sequence>
      <xsd:element name="НомерПП" type="ТипНомерПоПорядку" />
      <xsd:element name="ФИО" type="ТипФИО" />
      <xsd:element name="СтраховойНомер" type="ТипСтраховойНомер" />
      <xsd:element name="ГодРождения">
        <xsd:simpleType>
          <xsd:restriction base="xsd:gYear">
            <xsd:minInclusive value="1900" />
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
      <xsd:element name="ДатаНачалаПериода" type="ТипДата" />
      <xsd:element name="ДатаКонцаПериода" type="ТипДата" />
      <xsd:element name="ОПСстраховаяЧасть" type="ТипДеньги" />
      <xsd:element name="ОПСнакопительнаяЧасть" type="ТипДеньги" />
      <xsd:element name="СтраховыеВзносыФФОМС" type="ТипДеньги" />
      <xsd:element name="СтраховыеВзносыТФОМС" type="ТипДеньги" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипСведенияОзадолженностиПоСтраховымВзносамНаОПСпоСостояниюНа31.12.2009">
    <xsd:sequence>
      <xsd:element name="ОстатокЗадолженностиНаНачалоРасчетногоПериода" type="ТипРасчетПоНачисленнымИуплаченнымЗадолженность" minOccurs="1" />
      <xsd:element name="УплаченоВотчетномПериоде" type="ТипРасчетПоНачисленнымИуплаченнымЗадолженность" minOccurs="1" />
      <xsd:element name="ОстатокЗадолженностиНаКонецРасчетногоПериода" type="ТипРасчетПоНачисленнымИуплаченнымЗадолженность" minOccurs="1" />
    </xsd:sequence>
  </xsd:complexType>
  <!-- Тип ВхДок-->
  <xsd:complexType name="ТипРасчетПоНачисленнымИуплаченнымСтраховымВзносам">
    <xsd:sequence>
      <xsd:element name="ОстатокЗадолженностиНаНачалоРасчетногоПериода2012" type="ТипРасчетПоНачисленнымИуплаченным" minOccurs="0" />
      <xsd:element name="НачисленоСначалаРасчетногоПериода2012" type="ТипНачисленоУплачено" />
      <xsd:element name="ДоначисленоСначалаРасчетногоПериода2012" type="ТипРасчетПоНачисленнымИуплаченным" minOccurs="0" />
      <xsd:element name="ВсегоКуплате2012" type="ТипРасчетПоНачисленнымИуплаченным" />
      <xsd:element name="УплаченоСначалаРасчетногоПериода2012" type="ТипНачисленоУплачено" />
      <xsd:element name="ВтомЧислеЗаПредыдущиеРасчетныеПериоды2012" type="ТипРасчетПоНачисленнымИуплаченным" />
      <xsd:element name="ОстатокЗадолженностиНаКонецРасчетногоПериода2012" type="ТипРасчетПоНачисленнымИуплаченным" minOccurs="0" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипРасчетСтраховыхВзносовПоУстановленномуТарифу">
    <xsd:sequence>
      <xsd:element name="КодТарифа" type="ТипКодУстановленногоТарифа" />
      <xsd:element name="НаОбязательноеПенсионноеСтрахование" type="ТипРасчетПоТарифу" />
      <xsd:element name="НаОбязательноеМедицинскоеСтрахование" type="ТипНачисленоСтраховыхВзносовПоТарифу" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипРасчетСтраховыхВзносовПоПониженномуТарифу">
    <xsd:sequence>
      <xsd:element name="РасчетПоВыплатамРаботникамИнвалидам" type="ТипРасчетПоТарифу" minOccurs="0" />
      <xsd:element name="НачисленоСтраховыхВзносовВпользуРаботниковИнвалидов" type="ТипНачисленоСтраховыхВзносовПоТарифу" minOccurs="0" />
      <xsd:element name="РасчетПоВыплатамРаботникамЕНВД" type="ТипРасчетПоТарифу" minOccurs="0" />
      <xsd:element name="НачисленоСтраховыхВзносовВпользуРаботниковЕНВД" type="ТипНачисленоСтраховыхВзносовПоТарифу" minOccurs="0" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипОснованияДляПримененияПониженногоТарифа">
    <xsd:sequence>
      <xsd:element name="Раздел3_1_СведенияДляПримененияПониженногоТарифа_ФЛ_Инвалиду" type="ТипСведенияДляПримененияПониженногоТарифа" minOccurs="0" />
      <!--xsd:element name="РасчетСоответствияУсловийНаПравоПримененияПониженногоТарифа" type="ТипРасчетСоответствияУсловийНаПравоПримененияПониженногоТарифа" minOccurs="0" /-->
    </xsd:sequence>
  </xsd:complexType>
  <!-- ВходящийДокумент  -->
  <xsd:simpleType name="ТипКалендарныйГод">
    <xsd:restriction base="xsd:gYear">
      <xsd:minInclusive value="2012" />
      <xsd:maxInclusive value="2012" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипНаименованиеОрганизации">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="160" />
      <xsd:minLength value="1" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипРегистрационныйНомерТФОМС">
    <xsd:restriction base="xsd:unsignedLong">
      <xsd:minInclusive value="0" />
      <xsd:maxInclusive value="999999999999999" />
      <xsd:totalDigits value="15" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипКодПоОКАТО">
    <xsd:restriction base="xsd:unsignedLong">
      <xsd:totalDigits value="11" />
      <xsd:minInclusive value="0" />
      <xsd:maxInclusive value="99999999999" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипКодПоОКВЭД">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="8" />
      <xsd:pattern value="\d{2}\.\d{2}\.\d{2}|\d{2}\.\d{2}\.\d{1}|\d{2}\.\d{2}|\d{2}\.\d{1}|\d{2}" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипКодПоОКПО">
    <xsd:restriction base="xsd:unsignedLong">
      <xsd:totalDigits value="10" />
      <xsd:minInclusive value="0" />
      <xsd:maxInclusive value="9999999999" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипКодПоОКОПФ">
    <xsd:restriction base="xsd:integer">
      <xsd:totalDigits value="2" />
      <xsd:minInclusive value="0" />
      <xsd:pattern value="\d{2}" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипКодПоОКФС">
    <xsd:restriction base="xsd:integer">
      <xsd:totalDigits value="2" />
      <xsd:minInclusive value="0" />
      <xsd:pattern value="\d{2}" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипКодОГРН">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="15" />
      <xsd:pattern value="\d{13}|\d{15}|0|" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипЛицоПодтверждающееСведения">
    <xsd:restriction base="xsd:integer">
      <xsd:totalDigits value="1" />
      <xsd:enumeration value="1" />
      <xsd:enumeration value="2" />
      <xsd:enumeration value="3" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипКодУстановленногоТарифа">
    <xsd:restriction base="xsd:string">
      <xsd:length value="2" />
      <xsd:enumeration value="00" />
      <xsd:enumeration value="01" />
      <xsd:enumeration value="02" />
      <xsd:enumeration value="03" />
      <xsd:enumeration value="04" />
      <xsd:enumeration value="05" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипКодСтроки">
    <xsd:restriction base="xsd:integer">
      <xsd:totalDigits value="3" />
      <xsd:minInclusive value="0" />
      <xsd:maxInclusive value="999" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипКодОтчетногоПериода">
    <xsd:restriction base="xsd:string">
      <xsd:enumeration value="03" />
      <xsd:enumeration value="3" />
      <xsd:enumeration value="06" />
      <xsd:enumeration value="6" />
      <xsd:enumeration value="09" />
      <xsd:enumeration value="9" />
      <xsd:enumeration value="12" />
      <xsd:length value="2" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="ТипНомерКорректировки">
    <xsd:restriction base="xsd:integer">
      <xsd:totalDigits value="3" />
      <xsd:minInclusive value="0" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--NEW_2012 Тип ДЛЯ ликвидации -->
  <xsd:simpleType name="ТипЛиквид">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="1" />
    </xsd:restriction>
  </xsd:simpleType>
  <!--NEW_2012 Типы ДЛЯ  раздела 4 по задолженности за прошлые периоды-->
  <xsd:complexType name="ТипСуммаДоначисленныхВзносовЗаПериод">
    <xsd:sequence>
      <xsd:element name="НомерПП" type="ТипНомерПоПорядку" />
      <xsd:element name="Год" type="xsd:gYear" />
      <xsd:element name="Месяц" minOccurs="0">
        <xsd:simpleType>
          <xsd:restriction base="xsd:integer">
            <xsd:minInclusive value="0" />
            <xsd:maxInclusive value="12" />
            <xsd:totalDigits value="2" />
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
      <xsd:element name="ОПСстраховаяЧасть" type="ТипДеньги" />
      <xsd:element name="ОПСнакопительнаяЧасть" type="ТипДеньги" />
      <xsd:element name="СтраховыеВзносыОМС" type="ТипДеньги" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипИтогоДоначисленныхВзносовЗаПериод">
    <xsd:sequence>
      <xsd:element name="ОПСстраховаяЧасть" type="ТипДеньги" />
      <xsd:element name="ОПСнакопительнаяЧасть" type="ТипДеньги" />
      <xsd:element name="СтраховыеВзносыОМС" type="ТипДеньги" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипСуммыДоначисленныхСтраховыхВзносов">
    <xsd:sequence>
      <xsd:element name="СуммаДоначисленныхВзносовЗаПериод" type="ТипСуммаДоначисленныхВзносовЗаПериод" minOccurs="1" maxOccurs="unbounded" />
      <xsd:element name="ИтогоДоначислено" type="ТипИтогоДоначисленныхВзносовЗаПериод" minOccurs="1" />
    </xsd:sequence>
  </xsd:complexType>
  <!--NEW_2012 Типы ДЛЯ  раздела 5 по обучающимся-->
  <xsd:complexType name="ТипСведенияОбОбучающемся">
    <xsd:sequence>
      <xsd:element name="НомерПП" type="ТипНомерПоПорядку" />
      <xsd:element name="ФИО" type="ТипФИО" />
      <xsd:element name="НомерСправкиОчленствеВстудОтряде" type="ТипНомер" />
      <xsd:element name="ДатаВыдачиСправкиОчленствеВстудОтряде" type="ТипДата" />
      <xsd:element name="НомерСправкиОбОчномОбучении" type="ТипНомер" />
      <xsd:element name="ДатаВыдачиСправкиОбОчномОбучении" type="ТипДата" />
      <xsd:element name="СуммыВыплатИвознаграждений" type="ТипРасчетСумм" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипРеквизитыЗаписиВреестре">
    <xsd:sequence>
      <xsd:element name="ДатаЗаписиВреестре" type="ТипДата" />
      <xsd:element name="НомерЗаписиВреестре" minOccurs="0">
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
            <xsd:maxLength value="20" />
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:element>
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипСведенияИзРеестраМДОО">
    <xsd:sequence>
      <xsd:element name="КодСтроки" type="ТипКодСтроки" />
      <xsd:element name="РеквизитыЗаписиВреестре" type="ТипРеквизитыЗаписиВреестре" minOccurs="0" maxOccurs="unbounded" />
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="ТипСведенияОВыплатахВпользуОбучающихся">
    <xsd:sequence>
      <xsd:element name="КоличествоОбучающихся" type="ТипЧислоЗЛ" />
      <xsd:element name="СведенияОбОбучающемся" type="ТипСведенияОбОбучающемся" minOccurs="1" maxOccurs="unbounded" />
      <xsd:element name="ИтогоВыплат" type="ТипРасчетСумм" minOccurs="1" />
      <xsd:element name="СведенияИзРеестраМДОО" type="ТипСведенияИзРеестраМДОО" minOccurs="1" />
    </xsd:sequence>
  </xsd:complexType>
</xsd:schema>