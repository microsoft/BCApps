<?xml version="1.0" encoding="utf-8"?>
<ChartDefinition xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="urn:schemas-microsoft-com:dynamics:NAV:MetaObjects" Type="Column">
	<Title>
    <Text ID="ENU">Production Remaining Qty for Key Items per Status - Primo</Text>
  </Title>
  <Table ID="5406">
    <Filters>
      <Filter>
        <Field Name="Date Filter" />
        <Value>010108..w</Value>
      </Filter>
      <Filter>
        <Field Name="Item No." />
        <Value>1000..1900</Value>
      </Filter>
		<Filter>
			<Field Name="Status" />
			<Value>Simulated|Planned|Firm Planned|Released</Value>
		</Filter>
    </Filters>
  </Table>
  <XAxis ShowTitle="true">
    <Title>
      <Text ID="ENU">Date Filter: 010108 to Work Date</Text>
    </Title>
    <Field Name="Item No." />
    <Caption>
      <Text ID="ENU">Item No.</Text>
    </Caption>
  </XAxis>
	<ZAxis ShowTitle="true">
		<Title>
			<Text ID="ENU">Status</Text>
		</Title>
		<Field Name="Status" />
		<Caption>
			<Text ID="ENU">Dimension Caption</Text>
		</Caption>
	</ZAxis>
  <YAxis ShowTitle="false">
    <Measures>
      <Measure Operator="Sum">
        <Field Name="Remaining Quantity" />
      </Measure>
     </Measures>
  </YAxis>
</ChartDefinition>